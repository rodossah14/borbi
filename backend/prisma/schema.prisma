// Bor-Bi Tech — schéma Prisma initial Étape 1
// Couvre : utilisateurs, établissements, produits, commandes,
// transactions signées OHADA, fidélité, journal d'audit append-only.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ----------------------------------------------------------------------------
// Enums
// ----------------------------------------------------------------------------

enum RoleUtilisateur {
  CLIENT
  COMMERCANT
  LIVREUR
  ADMINISTRATEUR
}

enum TypeEtablissement {
  BOUTIQUE
  RESTAURANT
  HOTEL
  ENTREPOT
  KIOSQUE
  SHOWROOM
  PRESTATAIRE
  PHARMACIE
  ARTISAN
}

// ACTIF : en service. EN_PAUSE : fermé temporairement (vacances, travaux).
// SUSPENDU : sanction admin (litige, fraude). SUPPRIME : soft delete R80,
// récupérable 30 jours via la date de suppression.
enum StatutEtablissement {
  ACTIF
  EN_PAUSE
  SUSPENDU
  SUPPRIME
}

enum NiveauFidelite {
  BRONZE
  ARGENT
  OR
  PLATINE
}

enum StatutCommande {
  PANIER
  CONFIRMEE
  EN_PREPARATION
  EN_LIVRAISON
  LIVREE
  ANNULEE
  LITIGE
}

enum TypeTransaction {
  VENTE
  LIVRAISON
  TRANSFERT_NATIONAL
  TRANSFERT_INTERNATIONAL
  REMBOURSEMENT
  ABONNEMENT_MENSUEL
}

enum StatutTransaction {
  EN_ATTENTE
  VALIDEE
  ECHOUEE
  REMBOURSEE
  LITIGE
}

enum ActionAudit {
  CONNEXION
  DECONNEXION
  CREATION_COMPTE
  TENTATIVE_INSCRIPTION
  INSCRIPTION_VALIDEE
  CHANGEMENT_MOT_DE_PASSE
  CHANGEMENT_EMAIL
  CREATION_ETABLISSEMENT
  MODIFICATION_ETABLISSEMENT
  BASCULEMENT_STATUT_ETABLISSEMENT
  SUPPRESSION_ETABLISSEMENT
  RESTAURATION_ETABLISSEMENT
  AJOUT_PRODUIT
  MODIFICATION_PRODUIT
  MISE_A_JOUR_STOCK
  ALERTE_STOCK
  CREATION_TRANSACTION
  VALIDATION_TRANSACTION
  ECHEC_OTP
  ACCES_GOD_MODE
  DECLENCHEMENT_SOS
}

// ----------------------------------------------------------------------------
// Modèles
// ----------------------------------------------------------------------------

model Utilisateur {
  id                  String   @id @default(cuid())
  telephone           String   @unique // format E.164
  email               String?  @unique
  motDePasseHash      String
  nomComplet          String
  // Code pays ISO-2 (SN, CI, etc.) — stocké en string pour rester souple
  codePays            String
  languePreferee      String   @default("fr")
  roles               RoleUtilisateur[]
  niveauFidelite      NiveauFidelite @default(BRONZE)
  pointsFidelite      Int      @default(0)
  estVerifie          Boolean  @default(false)
  estSuspendu         Boolean  @default(false)
  // Score de confiance vendeur (0-100). Initialement 100, ajusté par
  // les évaluations clients, les litiges et la régularité des livraisons.
  scoreConfiance      Int      @default(100)
  codeParrainage      String   @unique // ex: BORBI-SN-A3K7
  idParrain           String?
  parrain             Utilisateur?  @relation("Parrainage", fields: [idParrain], references: [id])
  filleuls            Utilisateur[] @relation("Parrainage")
  etablissements      Etablissement[]
  transactionsEmises  Transaction[] @relation("TransactionsEmises")
  transactionsRecues  Transaction[] @relation("TransactionsRecues")
  commandes           Commande[]
  evenementsAudit     EvenementAudit[]
  dateCreation        DateTime @default(now())
  dateMiseAJour       DateTime @updatedAt

  @@index([codePays])
  @@index([niveauFidelite])
}

model Etablissement {
  id              String   @id @default(cuid())
  idProprietaire  String
  proprietaire    Utilisateur @relation(fields: [idProprietaire], references: [id], onDelete: Cascade)
  type            TypeEtablissement
  statut          StatutEtablissement @default(ACTIF)
  nom             String
  description     String?
  codePays        String
  ville           String
  adresse         String?
  telephone       String?
  // Horaires d'ouverture sous forme JSON libre, ex:
  // { "lundi": "08:00-19:00", "mardi": "08:00-19:00", "dimanche": "ferme" }
  horaires        Json?
  logoUrl         String?
  latitude        Float?
  longitude       Float?
  numeroNinea     String?
  // R80 — soft delete : SUPPRIME + dateSuppression permettent récupération
  // pendant 30 jours par un job cron, puis purge effective.
  dateSuppression DateTime?
  produits        Produit[]
  commandes       Commande[]
  dateCreation    DateTime @default(now())
  dateMiseAJour   DateTime @updatedAt

  @@index([idProprietaire])
  @@index([codePays, ville])
  @@index([type])
  @@index([statut])
}

model Produit {
  id              String   @id @default(cuid())
  idEtablissement String
  etablissement   Etablissement @relation(fields: [idEtablissement], references: [id], onDelete: Cascade)
  nom             String
  description     String?
  // Toujours stocké en XOF, converti à l'affichage selon la devise du client
  prixFCFA        Int
  // Catégorie produit (alimentation, vêtements, électronique, etc.).
  // Texte libre pour l'instant — à normaliser via taxonomie quand le catalogue
  // sera suffisamment dense pour justifier des facets.
  categorie       String
  // Stock à la création — snapshot immuable. Nécessaire pour calculer la
  // vélocité de vente et l'alerte de rupture J-7.
  stockInitial    Int
  stockActuel     Int      @default(0)
  stockMinimum    Int      @default(5)
  estDisponible   Boolean  @default(true)
  imageUrls       String[]
  // Compteur de consultations (incrémenté par obtenirProduit, atomique
  // côté Postgres via prisma { increment: 1 }). Utile pour le scoring
  // de pertinence et les analytics commerçant.
  vues            Int      @default(0)
  lignesCommande  LigneCommande[]
  dateCreation    DateTime @default(now())
  dateMiseAJour   DateTime @updatedAt

  @@index([idEtablissement])
  @@index([categorie])
}

model Commande {
  id              String   @id @default(cuid())
  numeroCommande  String   @unique // ex: BB-2026-000123 lisible humain
  idClient        String
  client          Utilisateur @relation(fields: [idClient], references: [id])
  idEtablissement String
  etablissement   Etablissement @relation(fields: [idEtablissement], references: [id])
  statut          StatutCommande @default(PANIER)
  montantTotalFcfa Int
  lignes          LigneCommande[]
  transactions    Transaction[]
  dateCreation    DateTime @default(now())
  dateMiseAJour   DateTime @updatedAt

  @@index([idClient])
  @@index([idEtablissement])
  @@index([statut])
}

model LigneCommande {
  id              String   @id @default(cuid())
  idCommande      String
  commande        Commande @relation(fields: [idCommande], references: [id], onDelete: Cascade)
  idProduit       String
  produit         Produit  @relation(fields: [idProduit], references: [id])
  quantite        Int
  prixUnitaireFcfa Int     // figé au moment de la commande
}

model Transaction {
  id                String   @id @default(cuid())
  type              TypeTransaction
  statut            StatutTransaction @default(EN_ATTENTE)
  montantBrutXof    Int
  montantBrutLocal  Int      // dans la devise du payeur
  codeDeviseLocal   String   @default("XOF")
  commissionXof     Int
  montantNetXof     Int
  empreinteSha256   String   // R-OHADA — signature de la transaction
  idEmetteur        String
  emetteur          Utilisateur @relation("TransactionsEmises", fields: [idEmetteur], references: [id])
  idDestinataire    String?
  destinataire      Utilisateur? @relation("TransactionsRecues", fields: [idDestinataire], references: [id])
  idCommande        String?
  commande          Commande?    @relation(fields: [idCommande], references: [id])
  donneesFournisseur Json?       // payload brut renvoyé par Wave / CinetPay
  dateCreation      DateTime @default(now())

  @@index([idEmetteur])
  @@index([idDestinataire])
  @@index([statut])
  @@index([dateCreation])
}

// Journal d'audit append-only (R25). Pas de champ updatedAt ni méthode
// de mise à jour : seules les insertions sont autorisées au niveau applicatif.
model EvenementAudit {
  id              String   @id @default(cuid())
  action          ActionAudit
  idUtilisateur   String?
  utilisateur     Utilisateur? @relation(fields: [idUtilisateur], references: [id])
  adresseIp       String?
  userAgent       String?
  donnees         Json
  empreinteSha256 String   // chaînée à l'événement précédent pour intégrité
  horodatage      DateTime @default(now())

  @@index([action])
  @@index([idUtilisateur])
  @@index([horodatage])
}
