# ============================================================================
# BOR-BI TECH — variables d'environnement (racine, copie dans .env)
# ----------------------------------------------------------------------------
# Les variables réelles sont chargées par chaque workspace (backend/frontend).
# Ce fichier sert de référence consolidée.
# ============================================================================

# --- Environnement général ---
NODE_ENV=development
TZ=Africa/Dakar

# --- Backend : base de données PostgreSQL (NeonDB) ---
DATABASE_URL=postgresql://utilisateur:motdepasse@hote.neon.tech/borbi?sslmode=require

# --- Backend : Redis (Upstash) — pas encore provisionné, valeur fictive ---
REDIS_URL=redis://default:motdepasse_fictif@fictif.upstash.io:6379

# --- Backend : authentification ---
JWT_SECRET=remplacer_par_un_secret_de_64_caracteres_minimum
JWT_REFRESH_SECRET=remplacer_par_un_autre_secret_de_64_caracteres_minimum
BCRYPT_ROUNDS=12

# --- Backend : chiffrement AES-256 (documents identité) ---
# Clé hex de 64 caractères (32 octets)
CHIFFREMENT_CLE_AES=remplacer_par_une_cle_hex_de_64_caracteres

# --- Backend : Twilio SMS/OTP — pas encore provisionné ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_NUMERO_EXPEDITEUR=

# --- Backend : Wave API (paiement) — sandbox disponible ---
WAVE_API_KEY=
WAVE_WEBHOOK_SECRET=
WAVE_BASE_URL=https://api.wave.com

# --- Backend : CinetPay — pas encore provisionné ---
CINETPAY_API_KEY=
CINETPAY_SITE_ID=
CINETPAY_SECRET_KEY=

# --- Backend : stockage S3/R2 — pas encore provisionné ---
STOCKAGE_FOURNISSEUR=r2
STOCKAGE_ENDPOINT=
STOCKAGE_BUCKET=
STOCKAGE_ACCESS_KEY=
STOCKAGE_SECRET_KEY=
STOCKAGE_REGION=auto

# --- Backend : Claude API (Anthropic Haiku) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODELE=claude-haiku-4-5-20251001

# --- Backend : DeepL traduction — pas encore provisionné ---
DEEPL_API_KEY=

# --- Backend : God Mode (R105) IP whitelist, séparées par des virgules ---
GOD_MODE_IPS_AUTORISEES=

# --- Backend : URL frontend autorisée pour CORS ---
URL_FRONTEND=http://localhost:5173

# --- Backend : port ---
PORT=4000

# --- Frontend : URL API backend ---
VITE_URL_API=http://localhost:4000/api

# --- Frontend : Mapbox — pas encore provisionné ---
VITE_MAPBOX_TOKEN=
